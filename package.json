{
  "name": "focus-cycles",
  "version": "1.0.0",
  "description": "Focus Cycles — built on Sebastian Marshall's Work Cycles framework.",
  "main": "main.js",
  "author": "Bud",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "package": "electron-packager . 'Focus Cycles' --platform=darwin --arch=arm64 --overwrite --out=dist --icon=build/icon.icns --app-bundle-id=com.bud.focuscycles --app-version=1.0.0 --ignore='^/dist$' --ignore='^/build$' --ignore='^/dist\\.previous-' --ignore='^/tasks$' --ignore='^/scripts$' --ignore='^/\\.overnight-npm-temp-backup' --ignore='^/\\.claude' --ignore='^/node_modules\\.dataless-broken-' --ignore='^/\\.gitignore$' --ignore='\\.md$' --ignore='^/node_modules/\\.electron-' ",
    "smoke": "node scripts/smoke-check.js",
    "test": "npm run smoke"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.1",
    "@types/http-cache-semantics": "^4.2.0",
    "electron": "^42.2.0",
    "electron-packager": "^17.1.2"
  }
}
